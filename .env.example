# Shopify App Credentials (from Shopify Partners dashboard)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_orders,write_orders,read_products

# App URL (your deployed backend)
APP_URL=https://your-app.vercel.app

# Session secret for cookies
SESSION_SECRET=random_secret_string_here

# Default AllScale environment for new installs (sandbox or production)
DEFAULT_ALLSCALE_ENV=sandbox
